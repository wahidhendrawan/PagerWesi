{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wahidhendrawan.github.io/PagerWesi/policy.schema.json",
  "title": "PagerWesi Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "const": 1
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "azure_admin_ports": {
          "$ref": "#/$defs/ports"
        },
        "gcp_admin_ports": {
          "$ref": "#/$defs/ports"
        }
      }
    },
    "aws": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vpc_flow_log_destination_arn": {
          "type": "string",
          "pattern": "^arn:"
        },
        "vpc_flow_log_iam_role_arn": {
          "type": "string",
          "pattern": "^arn:"
        }
      }
    },
    "exclude_resources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "ports": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      }
    }
  }
}
